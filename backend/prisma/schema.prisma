generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Report {
  id                   String                @id @default(cuid())
  trackingCode         String                @unique
  incidentType         String
  otherIncidentType    String?
  resolvedIncidentType String
  autoLocationText     String?
  manualLocationText   String?
  resolvedLocationText String
  latitude             Float?
  longitude            Float?
  victimCount          Int
  phoneNumber          String?
  notes                String?
  mediaCount           Int                   @default(0)
  status               String
  source               String                @default("Public Report")
  staffNote            String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  statusHistory        ReportStatusHistory[]
  triageAssessments    TriageAssessment[]
  mediaAttachments     MediaAttachment[]
}

model ReportStatusHistory {
  id        String   @id @default(cuid())
  reportId   String
  label      String
  createdAt  DateTime @default(now())

  report     Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
}

model TriageAssessment {
  id                   String   @id @default(cuid())
  reportId             String?
  unconscious          Boolean  @default(false)
  notBreathingNormally Boolean  @default(false)
  severeBleeding       Boolean  @default(false)
  multipleVictims      Boolean  @default(false)
  painScore            Int?
  score                Int
  urgency              String
  advisory             String
  reasons              String[]
  createdAt            DateTime @default(now())

  report               Report?  @relation(fields: [reportId], references: [id], onDelete: SetNull)
}

model ResourceItem {
  id        String   @id @default(cuid())
  category  String
  label     String
  value     String
  status    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MediaAttachment {
  id         String   @id @default(cuid())
  reportId    String
  fileName    String
  filePath    String
  mimeType    String?
  fileSize    Int?
  createdAt   DateTime @default(now())

  report      Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
}