generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model StaffUser {
  id           String            @id @default(cuid())
  name         String
  email        String            @unique
  staffId      String            @unique
  role         String
  passwordHash String
  isActive     Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  reportLogs   StaffActionLog[]
  resourceLogs ResourceActionLog[]
}

model Report {
  id                   String                @id @default(cuid())
  trackingCode         String                @unique
  incidentType         String
  otherIncidentType    String?
  resolvedIncidentType String
  autoLocationText     String?
  manualLocationText   String?
  resolvedLocationText String
  latitude             Float?
  longitude            Float?
  victimCount          Int
  phoneNumber          String?
  notes                String?
  mediaCount           Int                   @default(0)
  status               String
  source               String                @default("Public Report")
  staffNote            String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  statusHistory        ReportStatusHistory[]
  triageAssessments    TriageAssessment[]
  mediaAttachments     MediaAttachment[]
  staffLogs            StaffActionLog[]
}

model ReportStatusHistory {
  id        String   @id @default(cuid())
  reportId   String
  label      String
  createdAt  DateTime @default(now())

  report     Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
}

model TriageAssessment {
  id                   String   @id @default(cuid())
  reportId             String?
  unconscious          Boolean  @default(false)
  notBreathingNormally Boolean  @default(false)
  severeBleeding       Boolean  @default(false)
  multipleVictims      Boolean  @default(false)
  painScore            Int?
  score                Int
  urgency              String
  advisory             String
  reasons              String[]
  createdAt            DateTime @default(now())

  report               Report?  @relation(fields: [reportId], references: [id], onDelete: SetNull)
}

model ResourceItem {
  id          String              @id @default(cuid())
  category    String
  label       String
  value       String
  status      String
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  actionLogs  ResourceActionLog[]
}

model MediaAttachment {
  id         String   @id @default(cuid())
  reportId    String
  fileName    String
  filePath    String
  mimeType    String?
  fileSize    Int?
  createdAt   DateTime @default(now())

  report      Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
}

model StaffActionLog {
  id          String     @id @default(cuid())
  reportId     String
  actionType   String
  status       String?
  note         String?
  actorName    String?
  actorUserId  String?
  createdAt    DateTime  @default(now())

  report       Report     @relation(fields: [reportId], references: [id], onDelete: Cascade)
  actorUser    StaffUser? @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
}

model ResourceActionLog {
  id          String     @id @default(cuid())
  resourceId   String
  actionType   String
  note         String?
  actorName    String?
  actorUserId  String?
  createdAt    DateTime  @default(now())

  resource     ResourceItem @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  actorUser    StaffUser?   @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
}